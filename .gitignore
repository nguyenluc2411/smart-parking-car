# =============================================================================
# Smart Parking Car – .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS – KHÔNG BAO GIỜ COMMIT
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.jks

# -----------------------------------------------------------------------------
# JAVA / MAVEN
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
env/
pip-log.txt
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# AI MODELS (quá lớn để commit, mount vào container khi chạy)
# -----------------------------------------------------------------------------
*.pt
*.onnx
*.engine
*.trt
models/

# -----------------------------------------------------------------------------
# NODE / NEXT.JS
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
# Không ignore docker-compose.yml (cần commit)
# Nhưng ignore override files chứa local config
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
*.sql.bak
postgres-data/
kafka-data/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# TEST COVERAGE
# -----------------------------------------------------------------------------
coverage/
.coverage
htmlcov/
jacoco.xml
surefire-reports/

# -----------------------------------------------------------------------------
# MONITORING DATA (tạo runtime, không commit)
# -----------------------------------------------------------------------------
prometheus-data/
grafana-data/
alertmanager-data/

# -----------------------------------------------------------------------------
# CLAUDE / AI TOOLING – KHÔNG push (theo yêu cầu)
# -----------------------------------------------------------------------------
.claude/
{.claude/
.mcp.json
CLAUDE.md
**/CLAUDE.md

# -----------------------------------------------------------------------------
# PYTHON VENV (tên .venv-alpr KHÔNG khớp pattern .venv/ ở trên)
# -----------------------------------------------------------------------------
.venv-alpr/
.venv*/
**/.venv*/

# -----------------------------------------------------------------------------
# ML — datasets tải từ mạng + script train (không phải code chạy hệ thống) → loại cả thư mục
# -----------------------------------------------------------------------------
ml/
runs/
*.zip

# -----------------------------------------------------------------------------
# RESEARCH / TEST FIXTURES (ảnh + video test, binary — không phải code)
# -----------------------------------------------------------------------------
backend/edge-agent/samples/

# -----------------------------------------------------------------------------
# FLUTTER
# -----------------------------------------------------------------------------
.dart_tool/
**/.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
