# edge-agent configuration (12-Factor). Copy to .env for local runs.

# Auth — X-API-Key required on /api/v1/* endpoints
EDGE_API_KEY=dev-edge-key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TOPIC_PLATE_DETECTED=parking.plate.detected
TOPIC_GATE_COMMAND=parking.gate.command
TOPIC_GATE_STATE=parking.gate.state        # PRODUCE: barrier state -> parking-service (BR-006-2)
CONSUMER_GROUP=edge-agent

# ALPR pipeline
ALPR_MODE=simulate                         # simulate | real
ALPR_MODEL_PATH=/app/models/yolov8s_vn.pt  # used when ALPR_MODE=real
MODEL_VERSION=yolov8s_vn_v1.0
CONFIDENCE_THRESHOLD=0.85                   # BR-001-2
RETRY_ATTEMPTS=3                            # BR-001-2

# Barrier simulation
GATE_AUTO_CLOSE_SECONDS=10                  # BR-006-2

# Phase 1 — automatic RTSP/USB capture (off by default; demo uses browser auto-scan)
AUTO_CAPTURE_ENABLED=false
AUTO_CAPTURE_ENTRY_SOURCE=                   # e.g. 0 or rtsp://cam-entry
AUTO_CAPTURE_EXIT_SOURCE=                    # e.g. 1 or rtsp://cam-exit
AUTO_CAPTURE_INTERVAL=2.0
AUTO_CAPTURE_COOLDOWN=8.0                    # seconds after publish (not 60–120s)
AUTO_CAPTURE_FRAMES=5
AUTO_CAPTURE_FRAME_GAP=0.2
AUTO_CAPTURE_MIN_VOTES=2
# AUTO_CAPTURE_MIN_CONFIDENCE=                 # optional; defaults to CONFIDENCE_THRESHOLD
