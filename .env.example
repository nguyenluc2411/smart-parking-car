# =============================================================================
# Smart Parking Car – Environment Variables
# =============================================================================
# HƯỚNG DẪN:
#   1. Copy file này: cp .env.example .env
#   2. Thay toàn bộ giá trị có prefix "change_me_" bằng giá trị thực
#   3. KHÔNG commit file .env lên git
#   4. JWT_SECRET phải >= 256 bit (32 ký tự random)
# =============================================================================

# -----------------------------------------------------------------------------
# PROJECT
# -----------------------------------------------------------------------------
VERSION=1.0.0
COMPOSE_PROJECT_NAME=smart-parking-car

# -----------------------------------------------------------------------------
# ADMIN-SERVICE (:8083) — admin_db (:5433)
# -----------------------------------------------------------------------------
ADMIN_SERVICE_PORT=8083
ADMIN_DB_HOST=admin-db
ADMIN_DB_PORT=5432
ADMIN_DB_NAME=admin_db
ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=change_me_admin_db_password

# Spring datasource URL (dùng trong docker compose)
ADMIN_DB_URL=jdbc:postgresql://admin-db:5432/admin_db

# -----------------------------------------------------------------------------
# PARKING-SERVICE (:8081) — parking_db (:5434)
# -----------------------------------------------------------------------------
PARKING_SERVICE_PORT=8081
PARKING_DB_HOST=parking-db
PARKING_DB_PORT=5432
PARKING_DB_NAME=parking_db
PARKING_DB_USER=parking_user
PARKING_DB_PASSWORD=change_me_parking_db_password

PARKING_DB_URL=jdbc:postgresql://parking-db:5432/parking_db

# -----------------------------------------------------------------------------
# BILLING-SERVICE (:8082) — billing_db (:5435)
# -----------------------------------------------------------------------------
BILLING_SERVICE_PORT=8082
BILLING_DB_HOST=billing-db
BILLING_DB_PORT=5432
BILLING_DB_NAME=billing_db
BILLING_DB_USER=billing_user
BILLING_DB_PASSWORD=change_me_billing_db_password

BILLING_DB_URL=jdbc:postgresql://billing-db:5432/billing_db

# -----------------------------------------------------------------------------
# EDGE-AGENT (:8000) — Python FastAPI, stateless
# -----------------------------------------------------------------------------
EDGE_AGENT_PORT=8000
EDGE_API_KEY=change_me_edge_api_key_min_32_chars
ALPR_CONFIDENCE_THRESHOLD=0.85
ALPR_RETRY_ATTEMPTS=3
MODEL_PATH=/app/models/yolov8s_vn.pt

# -----------------------------------------------------------------------------
# JWT (dùng chung cho admin-service phát hành, các service khác validate)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_must_be_at_least_32_characters_long
JWT_EXPIRATION_SECONDS=28800
# 28800 = 8 giờ

# -----------------------------------------------------------------------------
# KAFKA (KRaft mode, không ZooKeeper)
# -----------------------------------------------------------------------------
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLUSTER_ID=smart-parking-car-cluster-001

# Consumer group IDs
PARKING_KAFKA_GROUP_ID=parking-service
BILLING_KAFKA_GROUP_ID=billing-service
ADMIN_KAFKA_GROUP_ID=admin-service

# Kafka log retention
KAFKA_LOG_RETENTION_HOURS=168
# 168 = 7 ngày

# -----------------------------------------------------------------------------
# MINIO — object storage cho ảnh chụp xe vào/ra (truy vết)
# -----------------------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key_min_8_chars
MINIO_BUCKET=parking-frames
# Endpoint nội bộ (services trong compose dùng để upload/đọc)
MINIO_ENDPOINT=minio:9000
# Endpoint public — parking-service ký presigned URL theo host này để trình duyệt/mobile truy cập được
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# ADMIN DASHBOARD — Next.js (:3000)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3000
NEXT_PUBLIC_PARKING_API_URL=http://localhost:8081
NEXT_PUBLIC_BILLING_API_URL=http://localhost:8082
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8083

# -----------------------------------------------------------------------------
# MONITORING — Prometheus + Grafana
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
KAFKA_EXPORTER_PORT=9308

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_admin_password
GF_SERVER_ROOT_URL=http://localhost:3001
GRAFANA_WEBHOOK_URL=https://example.com/webhook

# Prometheus scrape interval
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# -----------------------------------------------------------------------------
# SPRING PROFILES
# -----------------------------------------------------------------------------
# docker = dùng trong Docker Compose
# local  = chạy trực tiếp trên máy (DB/Kafka ở localhost)
# test   = chạy unit/integration test
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------------------------
# JVM OPTIONS (Spring Boot services)
# -----------------------------------------------------------------------------
ADMIN_JAVA_OPTS=-Xms128m -Xmx512m -XX:+UseG1GC
PARKING_JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC
BILLING_JAVA_OPTS=-Xms128m -Xmx512m -XX:+UseG1GC

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
LOG_LEVEL_APP=INFO
# Tắt SQL logging trong production, bật khi debug
LOG_LEVEL_SQL=WARN
